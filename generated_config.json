{
    "simulator": {
        "name": "simulate_exponential_decay",
        "parameter_container": "theta",
        "rng_argument": "rng"
    },
    "inference": {
        "inferred_parameters": [
            "decay_rate",
            "initial_value"
        ],
        "prior_bounds": {
            "decay_rate": [
                0.0,
                5.0
            ],
            "initial_value": [
                0.0,
                5.0
            ]
        }
    },
    "fixed_values": {
        "noise_sd": 0.5
    },
    "fixed_value_path": {
        "time": "time.npy"
    },
    "observed_data_path": "observed_data.npy",
    "abc": {
        "epsilon": 0.15,
        "n_simulations": 100000,
        "random_seed": 123
    },
    "functions": {
        "summary": "mean_std_summary",
        "distance": "euclidean_distance"
    }
}